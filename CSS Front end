body {
    background-color: #1e1e1e;
    color: white;
    font-family: Arial;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    
}

.container {
    background: #2d2d2d;
    padding: 30px;
    border-radius: 10px;
    text-align: center;
    width: 300px;
}

input {
    padding: 10px;
    width: 80%;
    margin-bottom: 10px;
}

button {
    padding: 10px;
    width: 85%;
    cursor: pointer;
}

.weather-box {
    margin-top: 20px;
}
